{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!.*\\.[a-zA-Z0-9]+$).*)",
      "has": [{ "type": "host", "value": "frontdesk.zenithintelligence.ai" }],
      "destination": "/frontdesk.html"
    },
    {
      "source": "/frontdesk",
      "destination": "/frontdesk.html"
    }
  ]
}
